---
import ProjectsGrid from "./ProjectsGrid.astro";
import TrueResonanceBanner from "./TrueResonanceBanner.astro";
import { getFeaturedProjects } from "../data/projects";

const featuredProjects = getFeaturedProjects();
---

<section id="featured-projects">
  <div class="featured-projects-top">
    <p class="featured-label">FEATURED PROJECTS</p>
    <TrueResonanceBanner />
  </div>
  <ProjectsGrid projects={featuredProjects} />
</section>

<style>
  #featured-projects {
    border-radius: 0 0 2rem 2rem;
    background: var(--background-light);
    position: relative;
    z-index: 5;
    margin-top: 0;
    margin-bottom: -1rem;
    padding: 0 0 3rem;
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3rem);
  }

  .featured-projects-top {
    background: var(--background-dark, #0a0a0f);
    position: relative;
    z-index: 4;
    padding: 5rem 0 7rem;
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3rem);
    isolation: isolate;
  }

  .featured-label {
    font-size: clamp(1.55rem, 3.4vw, 2.6rem);
    font-weight: var(--font-bold);
    letter-spacing: 0.08em;
    color: var(--white);
    text-transform: uppercase;
    margin: 0;
    text-align: center;
    font-family: "Montserrat", sans-serif;
    position: relative;
    z-index: 1;
  }

  .featured-projects-top::before,
  .featured-projects-top::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    pointer-events: none;
    z-index: 0;
  }

  .featured-projects-top::before {
    top: -5rem;
    height: 5rem;
    background: linear-gradient(to bottom, rgba(11, 18, 44, 0), var(--background-dark, #0a0a0f));
  }

  .featured-projects-top::after {
    bottom: -5rem;
    height: 5rem;
    background: linear-gradient(to bottom, var(--background-dark, #0a0a0f), var(--background-light));
  }

</style>
