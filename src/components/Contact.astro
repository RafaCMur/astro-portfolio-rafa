---
import { Icon } from "astro-icon/components";
import { ADDRESS, EMAIL, LINKEDIN_URL, PHONE } from "../consts";

const MAILTO_LINK = `mailto:${EMAIL}`;
const PHONE_LINK = `tel:${PHONE}`;
---

<section id="contact">
  <!-- Hero Section -->
  <div class="contact-hero">
    <div class="hero-content">
      <p class="hero-subtitle">READY TO GET STARTED?</p>
      <h1 class="hero-title">
        LET'S WORK<br />
        <span class="yellow-text-gradient">TOGETHER</span>
      </h1>
      <p class="hero-description">
        Transform your vision into digital reality. Contact me to create
        exceptional web solutions that drive your business towards success.
      </p>
    </div>
  </div>

  <!-- Contact Form Section -->
  <div class="contact-section">
    <div class="contact-container">
      <!-- Contact Info -->
      <div class="contact-info">
        <h2 class="info-title">CONTACT INFORMATION</h2>
        <p class="info-description">
          I'm here to help you materialize your ideas.
        </p>

        <div class="contact-details">
          <div class="contact-item">
            <Icon name="mail" size={20} class="contact-icon" />
            <a href={MAILTO_LINK} class="contact-link">{EMAIL}</a>
          </div>

          <div class="contact-item">
            <Icon name="phone" size={20} class="contact-icon" />
            <a href={PHONE_LINK} class="contact-link">{PHONE}</a>
          </div>

          <div class="contact-item">
            <Icon name="location-pin" size={20} class="contact-icon" />
            <span class="contact-text">{ADDRESS}</span>
          </div>

          <div class="contact-item">
            <Icon name="linkedin" size={20} class="contact-icon" />
            <a href={LINKEDIN_URL} target="_blank" class="contact-link"
              >LinkedIn</a
            >
          </div>
        </div>
      </div>

      <div class="contact-form">
        <h2 class="form-title">LET'S CONNECT</h2>
        <p class="form-description">
          If you'd like to talk about a role, a collaboration, or a project, the
          fastest way to reach me is directly through email, phone, or LinkedIn.
        </p>
        <div class="contact-actions">
          <a href={MAILTO_LINK} class="contact-action-button primary-action">
            EMAIL ME
            <Icon name="arrow-up-right" size={20} class="submit-icon" />
          </a>
          <a
            href={LINKEDIN_URL}
            target="_blank"
            rel="noreferrer"
            class="contact-action-button secondary-action"
          >
            MESSAGE ON LINKEDIN
            <Icon name="arrow-up-right" size={20} class="submit-icon" />
          </a>
        </div>
        <div class="direct-contact-card">
          <div class="direct-contact-item">
            <span class="direct-contact-label">EMAIL</span>
            <a href={MAILTO_LINK} class="direct-contact-link">{EMAIL}</a>
          </div>
          <div class="direct-contact-item">
            <span class="direct-contact-label">PHONE</span>
            <a href={PHONE_LINK} class="direct-contact-link">{PHONE}</a>
          </div>
          <div class="direct-contact-item">
            <span class="direct-contact-label">LOCATION</span>
            <span class="direct-contact-value">{ADDRESS}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #contact {
    background: var(--background-light);
  }

  /* Hero Section */
  .contact-hero {
    background:
      linear-gradient(135deg, rgba(30, 56, 96, 0.85), rgba(45, 74, 90, 0.75)),
      url("/images/minimalist-laptop-and-plant.jpg") center/cover;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: white;
    position: relative;
  }

  .hero-content {
    max-width: 800px;
    padding: 2rem;
  }

  .hero-subtitle {
    font-size: 0.9rem;
    letter-spacing: 2px;
    color: var(--primary-color);
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 2rem;
    color: white;
  }

  .hero-description {
    font-size: 1.1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Contact Section */
  .contact-section {
    padding: 5rem 2rem;
    background: var(--background-light);
  }

  .contact-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: start;
  }

  /* Contact Info */
  .contact-info {
    color: white;
  }

  .info-title {
    font-size: clamp(1.8rem, 3vw, 2.2rem);
    font-weight: 700;
    color: white;
    margin-bottom: 1.5rem;
    letter-spacing: 1px;
  }

  .info-description {
    font-size: 1.1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 3rem;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease;
  }

  .contact-item:last-child {
    border-bottom: none;
  }

  .contact-item:hover {
    padding-left: 0.5rem;
  }

  .contact-icon {
    color: var(--primary-color);
    flex-shrink: 0;
    opacity: 0.8;
  }

  .contact-link {
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    font-weight: 400;
    transition: color 0.3s ease;
  }

  .contact-link:hover {
    color: var(--primary-color);
  }

  .contact-text {
    color: rgba(255, 255, 255, 0.8);
    font-weight: 400;
  }

  /* Contact Form */
  .contact-form {
    background: transparent;
  }

  .form-title {
    font-size: clamp(1.6rem, 2.5vw, 2rem);
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
    letter-spacing: 1px;
  }

  .form-description {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 2.5rem;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .contact-action-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-width: 220px;
    padding: 1rem 1.5rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 1px;
    transition: all 0.3s ease;
  }

  .primary-action {
    background: var(--primary-color);
    color: var(--background-dark);
  }

  .primary-action:hover {
    background: #7dd3fc;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(94, 232, 232, 0.3);
  }

  .secondary-action {
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.04);
    color: white;
  }

  .secondary-action:hover {
    border-color: rgba(94, 232, 232, 0.45);
    background: rgba(94, 232, 232, 0.08);
    transform: translateY(-2px);
  }

  .direct-contact-card {
    display: grid;
    gap: 1rem;
    padding: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(10px);
  }

  .direct-contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .direct-contact-item:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .direct-contact-label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--primary-color);
  }

  .direct-contact-link,
  .direct-contact-value {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1rem;
    text-decoration: none;
    word-break: break-word;
  }

  .direct-contact-link:hover {
    color: var(--primary-color);
  }

  .submit-icon {
    transition: transform 0.3s ease;
  }

  .contact-action-button:hover .submit-icon {
    transform: translate(2px, -2px);
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .contact-hero {
      min-height: 50vh;
      padding: 1rem;
    }

    .contact-section {
      padding: 3rem 1rem;
    }

    .contact-container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .contact-form {
      padding: 1.5rem 0;
    }
  }
</style>
