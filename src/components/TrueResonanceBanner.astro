---
import { TRUE_RESONANCE_PLAY_STORE_URL } from "../consts";
---

<div id="true-resonance-banner">
  <div class="banner-inner">
    <a href={TRUE_RESONANCE_PLAY_STORE_URL} target="_blank" rel="noopener noreferrer">
      <img
        class="banner-image"
        src="/images/true-resonance-banner.jpg"
        alt="True Resonance Player banner"
        loading="lazy"
      />
    </a>

    <div class="banner-info">
      <h2 class="banner-title">True Resonance Player</h2>
      <p class="banner-copy">
        <strong>True Resonance</strong> is a modern 432 Hz audio player with real-time tuning,
        designed for calm, focused listening.<br />
        <span class="banner-copy-highlight">Trusted by <strong>5K+ listeners</strong>.</span>
      </p>

      <a
        class="banner-cta"
        href={TRUE_RESONANCE_PLAY_STORE_URL}
        target="_blank"
        rel="noopener noreferrer"
      >
        View on Play Store →
      </a>
    </div>
  </div>
</div>

<style>
  #true-resonance-banner {
    background: var(--background-dark, #0a0a0f);
    padding: 5rem 0 6rem;
    position: relative;
    z-index: 4;
    isolation: isolate;
  }

  #true-resonance-banner::before,
  #true-resonance-banner::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    height: 5rem;
    pointer-events: none;
    z-index: 0;
  }

  #true-resonance-banner::before {
    top: -5rem;
    background: linear-gradient(to bottom, rgba(10, 10, 15, 0), var(--background-dark, #0a0a0f));
  }

  #true-resonance-banner::after {
    bottom: -5rem;
    background: linear-gradient(to bottom, var(--background-dark, #0a0a0f), var(--background-light));
  }

  .banner-inner {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .banner-image {
    width: 100%;
    max-width: 700px;
    border-radius: 1rem;
    display: block;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
  }

  .banner-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .banner-title {
    font-size: clamp(1.65rem, 3.6vw, 2.25rem);
    font-weight: var(--font-bold);
    font-family: "Montserrat", sans-serif;
    color: var(--white);
    margin: 0;
  }

  .banner-copy {
    font-size: 1rem;
    color: var(--dirty-white);
    margin: 0;
    max-width: 480px;
    line-height: 1.5;
    text-wrap: balance;
  }

  .banner-copy-highlight {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 1.12rem;
    font-weight: var(--font-semi-bold);
    color: var(--white);
  }

  .banner-cta {
    margin-top: 0.25rem;
    font-size: 0.9rem;
    font-weight: var(--font-semi-bold);
    color: var(--primary-color);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: opacity 200ms ease;
  }

  .banner-cta:hover {
    opacity: 0.75;
  }
</style>
