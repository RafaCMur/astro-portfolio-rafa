---
---

<section id="true-resonance-banner">
  <div class="banner-inner">
    <p class="featured-label">FEATURED PROJECT</p>

    <img
      class="banner-image"
      src="/images/true-resonance-banner.jpg"
      alt="True Resonance Player banner"
      loading="lazy"
    />

    <div class="banner-info">
      <h2 class="banner-title">True Resonance Player</h2>
      <p class="banner-description">Modern 432 Hz audio player with real-time tuning</p>
      <div class="banner-badges">
        <span class="badge">5K+ users</span>
        <span class="badge">Android</span>
        <span class="badge">432 Hz</span>
      </div>

      <!-- TODO: The en-US hardcoded should be dynamic when internationalization is implemented -->
      <a
        class="banner-cta"
        href="https://play.google.com/store/apps/details?id=com.trueresonance.player&hl=en_US"
        target="_blank"
        rel="noopener noreferrer"
      >
        View on Play Store →
      </a>
    </div>
  </div>
</section>

<style>
  #true-resonance-banner {
    background: var(--background-dark, #0a0a0f);
    padding: clamp(3rem, 6vw, 5rem) 0;
    position: relative;
    z-index: 4;
  }

  .banner-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .featured-label {
    font-size: 0.75rem;
    font-weight: var(--font-bold);
    letter-spacing: 0.2em;
    color: var(--primary-color);
    text-transform: uppercase;
    margin: 0;
  }

  .banner-image {
    width: 100%;
    max-width: 700px;
    border-radius: 1rem;
    display: block;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
  }

  .banner-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .banner-title {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: var(--font-bold);
    font-family: "Montserrat", sans-serif;
    color: var(--white);
    margin: 0;
  }

  .banner-description {
    font-size: 1rem;
    color: var(--dirty-white);
    margin: 0;
    max-width: 480px;
    line-height: 1.5;
  }

  .banner-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .badge {
    font-size: 0.75rem;
    font-weight: var(--font-semi-bold);
    letter-spacing: 0.05em;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(94, 232, 232, 0.4);
    color: var(--primary-color);
    background: rgba(94, 232, 232, 0.07);
  }

  .banner-cta {
    margin-top: 0.25rem;
    font-size: 0.9rem;
    font-weight: var(--font-semi-bold);
    color: var(--primary-color);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: opacity 200ms ease;
  }

  .banner-cta:hover {
    opacity: 0.75;
  }
</style>
