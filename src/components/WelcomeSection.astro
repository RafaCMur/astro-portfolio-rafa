---

---

<section id="welcome">
  <div class="section-content">
    <div class="welcome-section" data-animate-root>
      <div class="welcome-orb welcome-orb-left"></div>
      <div class="welcome-orb welcome-orb-right"></div>
      <div class="welcome-grid"></div>
      <h1 class="welcome-title gradient-text" data-animate-item="title">
        WELCOME TO MY DIGITAL OCEAN
      </h1>
      <p class="welcome-subtitle" data-animate-item="subtitle">
        Frontend Developer specialized in creating exceptional web experiences
        that combine design and performance
      </p>
      <div class="stats-highlight" data-animate-item="stats">
        <span class="big-number">+10</span>
        <span class="stats-label"
          >PROJECTS COMPLETED<br />EXPERIENCE AS FREELANCE</span
        >
      </div>
    </div>
  </div>
</section>

<style>
  #welcome {
    border-radius: 2rem 2rem 0 0;
    position: relative;
    z-index: 2;
    margin-top: -2rem;
    background: var(--background-light);
  }

  .welcome-section {
    position: relative;
    overflow: hidden;
    text-align: center;
    padding-top: 5rem;
    padding-bottom: 3rem;
    margin-bottom: 3rem;
    isolation: isolate;
  }

  .welcome-grid,
  .welcome-orb {
    position: absolute;
    pointer-events: none;
  }

  .welcome-grid {
    inset: 0;
    background-image:
      linear-gradient(rgba(94, 232, 232, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(94, 232, 232, 0.08) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: radial-gradient(circle at center, black 35%, transparent 78%);
    opacity: 0.45;
    transform: translateY(18px) scale(1.02);
    transition:
      opacity 800ms ease,
      transform 900ms ease;
    z-index: -3;
  }

  .welcome-orb {
    width: 18rem;
    height: 18rem;
    border-radius: 9999px;
    filter: blur(60px);
    opacity: 0.22;
    transition:
      transform 900ms ease,
      opacity 900ms ease;
    z-index: -2;
  }

  .welcome-orb-left {
    top: 1rem;
    left: 8%;
    background: rgba(94, 232, 232, 0.7);
    transform: translate3d(-24px, 12px, 0) scale(0.9);
  }

  .welcome-orb-right {
    right: 10%;
    bottom: 0;
    background: rgba(59, 130, 246, 0.6);
    transform: translate3d(24px, -12px, 0) scale(0.92);
  }

  .welcome-title {
    font-size: 2.5rem;
    font-weight: var(--font-bold);
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
    font-family: "Montserrat", sans-serif;
  }

  .welcome-title,
  .welcome-subtitle,
  .stats-highlight {
    position: relative;
    z-index: 1;
    opacity: 0;
    transform: translateY(28px) scale(0.985);
    filter: blur(10px);
    transition:
      opacity 650ms ease,
      transform 650ms ease,
      filter 650ms ease;
  }

  .welcome-title {
    transition-delay: 80ms;
  }

  .welcome-subtitle {
    font-size: 1.1rem;
    color: var(--dirty-white);
    max-width: 600px;
    margin: 0 auto 3rem auto;
    line-height: 1.6;
    transition-delay: 180ms;
  }

  .stats-highlight {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    transition-delay: 280ms;
  }

  .welcome-section.is-visible .welcome-title,
  .welcome-section.is-visible .welcome-subtitle,
  .welcome-section.is-visible .stats-highlight {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }

  .welcome-section.is-visible .welcome-grid {
    opacity: 0.7;
    transform: translateY(0) scale(1);
  }

  .welcome-section.is-visible .welcome-orb-left,
  .welcome-section.is-visible .welcome-orb-right {
    opacity: 0.34;
    transform: translate3d(0, 0, 0) scale(1);
  }

  .big-number {
    font-size: 4rem;
    font-weight: var(--font-bold);
    color: var(--primary-color);
    font-family: "Montserrat", sans-serif;
    text-shadow: 0 0 24px rgba(94, 232, 232, 0.2);
  }

  .stats-label {
    font-size: 0.9rem;
    font-weight: var(--font-semi-bold);
    color: var(--dirty-white);
    letter-spacing: 0.05em;
    text-align: center;
    line-height: 1.4;
  }

  @media (prefers-reduced-motion: reduce) {
    .welcome-title,
    .welcome-subtitle,
    .stats-highlight,
    .welcome-grid,
    .welcome-orb {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }
  }

  @media (max-width: 768px) {
    .welcome-section {
      padding-bottom: 2rem;
    }

    .welcome-title {
      font-size: 2rem;
    }

    .big-number {
      font-size: 3rem;
    }

    .welcome-subtitle {
      font-size: 1rem;
      padding: 0 1rem;
    }

    .welcome-orb {
      width: 12rem;
      height: 12rem;
      filter: blur(40px);
    }
  }
</style>

<script>
  const root = document.querySelector("[data-animate-root]");

  if (root instanceof HTMLElement) {
    const mediaQuery = window.matchMedia("(prefers-reduced-motion: reduce)");

    if (mediaQuery.matches) {
      root.classList.add("is-visible");
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              root.classList.add("is-visible");
              observer.disconnect();
              break;
            }
          }
        },
        { threshold: 0.35 },
      );

      observer.observe(root);
    }
  }
</script>
