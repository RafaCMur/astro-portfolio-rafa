---

---

<section id="welcome">
  <div class="welcome-section">
    <div class="welcome-orb welcome-orb-left"></div>
    <div class="welcome-orb welcome-orb-right"></div>
    <div class="section-content">
      <div class="welcome-content">
        <h1 class="welcome-title gradient-text">WELCOME TO MY DIGITAL OCEAN</h1>
        <p class="welcome-subtitle">
          Frontend Developer specialized in creating exceptional web experiences
          that combine design and performance
        </p>
        <div class="stats-highlight">
          <div class="stat-item">
            <div class="big-number stat-number" data-target="10" data-prefix="+">
              <span class="stat-prefix" aria-hidden="true">+</span>
              <span class="stat-value">0</span>
            </div>
            <span class="stats-label">PROJECTS COMPLETED</span>
          </div>
          <div class="stat-item">
            <div class="big-number stat-number" data-target="5000" data-format="compact" data-suffix="+">
              <span class="stat-value">0</span>
              <span class="stat-suffix" aria-hidden="true">+</span>
            </div>
            <span class="stats-label">USERS ON A LIVE PRODUCT</span>
          </div>
          <div class="stat-item">
            <div class="big-number stat-number" data-target="100" data-suffix="%">
              <span class="stat-value">0</span>
              <span class="stat-suffix" aria-hidden="true">%</span>
            </div>
            <span class="stats-label">ON TIME DELIVERY</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #welcome {
    --welcome-bottom-space: clamp(5.5rem, 9vw, 8.5rem);
    --welcome-orb-right-offset: clamp(4rem, 8vw, 6.5rem);
    --welcome-orb-left-top: clamp(3.5rem, 6vw, 5.5rem);
    border-radius: 2rem 2rem 0 0;
    position: relative;
    z-index: 2;
    margin-top: -2rem;
    background: var(--background-light);
  }

  .welcome-section {
    position: relative;
    overflow: clip;
    text-align: center;
    padding-top: 5rem;
    padding-bottom: var(--welcome-bottom-space);
    margin-bottom: 0;
    isolation: isolate;
  }

  .welcome-content {
    position: relative;
    z-index: 1;
  }

  .welcome-orb {
    position: absolute;
    pointer-events: none;
  }

  .welcome-orb {
    width: 18rem;
    height: 18rem;
    border-radius: 9999px;
    filter: blur(28px);
    opacity: 0;
    z-index: -2;
    animation-duration: 1100ms, 6.5s;
    animation-timing-function: ease, ease-in-out;
    animation-iteration-count: 1, infinite;
    animation-direction: normal, alternate;
    animation-fill-mode: forwards, both;
    will-change: transform;
  }

  .welcome-orb-left {
    top: var(--welcome-orb-left-top);
    left: 8%;
    background: rgba(94, 232, 232, 0.7);
    transform: translate3d(-24px, 12px, 0) scale(0.9);
    animation-name: orbRevealLeft, orbFloatLeft;
    animation-delay: 180ms, 1200ms;
  }

  .welcome-orb-right {
    right: 10%;
    bottom: var(--welcome-orb-right-offset);
    background: rgba(59, 130, 246, 0.6);
    transform: translate3d(24px, -12px, 0) scale(0.92);
    animation-name: orbRevealRight, orbFloatRight;
    animation-delay: 260ms, 1000ms;
    animation-duration: 1200ms, 5.5s;
  }

  .welcome-title {
    font-size: 2.5rem;
    font-weight: var(--font-bold);
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
    font-family: "Montserrat", sans-serif;
  }

  .welcome-title,
  .welcome-subtitle,
  .stats-highlight {
    opacity: 0;
    transform: translateY(28px) scale(0.985);
    filter: blur(10px);
    animation: contentReveal 700ms ease forwards;
  }

  .welcome-title {
    animation-delay: 120ms;
  }

  .welcome-subtitle {
    font-size: 1.1rem;
    color: var(--dirty-white);
    max-width: 600px;
    margin: 0 auto 3rem auto;
    line-height: 1.6;
    animation-delay: 240ms;
  }

  .stats-highlight {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    align-items: start;
    max-width: 900px;
    margin: 0 auto;
    animation-delay: 360ms;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    padding: 1.25rem 1rem;
  }

  @keyframes contentReveal {
    0% {
      opacity: 0;
      transform: translateY(28px) scale(0.985);
      filter: blur(10px);
    }

    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  @keyframes orbRevealLeft {
    0% {
      opacity: 0;
      transform: translate3d(-48px, 18px, 0) scale(0.82);
    }

    100% {
      opacity: 0.34;
      transform: translate3d(-18px, 10px, 0) scale(0.94);
    }
  }

  @keyframes orbRevealRight {
    0% {
      opacity: 0;
      transform: translate3d(48px, -18px, 0) scale(0.84);
    }

    100% {
      opacity: 0.34;
      transform: translate3d(18px, -10px, 0) scale(0.95);
    }
  }

  @keyframes orbFloatLeft {
    0% {
      transform: translate3d(-56px, 28px, 0) scale(0.9);
    }

    50% {
      transform: translate3d(12px, -28px, 0) scale(1.03);
    }

    100% {
      transform: translate3d(56px, -38px, 0) scale(1.08);
    }
  }

  @keyframes orbFloatRight {
    0% {
      transform: translate3d(44px, -28px, 0) scale(0.91);
    }

    50% {
      transform: translate3d(-12px, 14px, 0) scale(1.02);
    }

    100% {
      transform: translate3d(-48px, 34px, 0) scale(1.07);
    }
  }

  .big-number {
    display: inline-flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0.08em;
    font-size: 4rem;
    font-weight: var(--font-bold);
    color: var(--primary-color);
    font-family: "Montserrat", sans-serif;
    text-shadow: 0 0 24px rgba(94, 232, 232, 0.2);
  }

  .stat-prefix,
  .stat-suffix {
    font-size: 0.6em;
    line-height: 1;
    transform: translateY(0.1em);
  }

  .stat-value {
    min-width: 2ch;
    text-align: center;
  }

  .stats-label {
    font-size: 0.9rem;
    font-weight: var(--font-semi-bold);
    color: var(--dirty-white);
    letter-spacing: 0.05em;
    text-align: center;
    line-height: 1.4;
    max-width: 16ch;
  }

  @media (max-width: 768px) {
    #welcome {
      --welcome-bottom-space: clamp(4.5rem, 14vw, 6rem);
      --welcome-orb-right-offset: clamp(3.25rem, 11vw, 5rem);
      --welcome-orb-left-top: clamp(4rem, 10vw, 5.25rem);
    }

    .welcome-title {
      font-size: 2rem;
    }

    .big-number {
      font-size: 3rem;
    }

    .stats-highlight {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      max-width: 320px;
    }

    .stat-item {
      padding: 0.75rem 0;
    }

    .welcome-subtitle {
      font-size: 1rem;
      padding: 0 1rem;
    }

    .welcome-orb {
      width: 12rem;
      height: 12rem;
      filter: blur(22px);
    }
  }
</style>

<script>
  const formatCompactNumber = (value: number) => {
    if (value >= 1000) {
      return `${Math.round(value / 1000)}K`;
    }
    return String(value);
  };

  const animateCounter = (statNumber: HTMLElement) => {
    const valueElement = statNumber.querySelector(".stat-value");
    if (!valueElement) return;

    const target = Number(statNumber.dataset.target ?? "0");
    const duration = 1400;
    const formatValue =
      statNumber.dataset.format === "compact"
        ? formatCompactNumber
        : (value: number) => String(value);
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (prefersReducedMotion) {
      valueElement.textContent = formatValue(target);
      return;
    }

    const startTime = performance.now();

    const tick = (currentTime: number) => {
      const progress = Math.min((currentTime - startTime) / duration, 1);
      const easedProgress = 1 - Math.pow(1 - progress, 3);
      const currentValue = Math.round(target * easedProgress);
      valueElement.textContent = formatValue(currentValue);
      if (progress < 1) requestAnimationFrame(tick);
    };

    requestAnimationFrame(tick);
  };

  document.addEventListener("DOMContentLoaded", () => {
    const statNumbers = document.querySelectorAll<HTMLElement>(
      ".stat-number[data-target]",
    );

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          animateCounter(entry.target as HTMLElement);
          obs.unobserve(entry.target);
        });
      },
      { threshold: 0.2 },
    );

    statNumbers.forEach((el) => observer.observe(el));
  });
</script>
