---

<section id="about">
  <!-- Hero Section with Background -->
  <div class="about-hero">
    <div class="hero-content">
      <h1 class="hero-title">
        RAFA CABANILLAS<br />
        <span class="yellow-text-gradient">FRONTEND DEVELOPER</span>
      </h1>
      <p class="hero-subtitle">
        REDEFINING THE WEB<br />
        DEVELOPMENT EXPERIENCE
      </p>
    </div>
  </div>

  <!-- Content Section -->
  <div class="about-content">
    <!-- Hero Quote Section -->
    <div class="hero-quote">
      <blockquote class="main-quote">
        "Every line of code transforms an idea into a digital experience that
        connects with people."
      </blockquote>
      <cite class="quote-author">— Rafa Cabanillas</cite>
    </div>

    <!-- Leadership Section -->
    <div class="leadership-section flex-row flex-wrap align-center gap-3 mt-5">
      <div class="flex-col">
        <h2 class="section-title">Inspirational Leadership</h2>
        <p class="section-text">
          Rafa Cabanillas is a React focused frontend developer who builds fast,
          usable products that drive <strong>real business results</strong>. He
          is passionate about creating innovative and user-friendly experiences
          that help businesses succeed. He turns your site into a growth engine
          that <strong>attracts, convinces, and sells</strong>.
        </p>
      </div>
    </div>

    <!-- Vision and Mission Section -->
    <div class="vision-mission-section flex-row gap-3 mt-2">
      <div class="leader-photo-parent flex-row align-center">
        <img
          src="/images/rafa-square-photo.png"
          alt="Rafa Cabanillas - Frontend Developer"
          class="leader-photo"
        />
      </div>
      <div class="vision-mission-text flex-col">
        <div class="vision-section flex-col">
          <h2 class="section-title">Vision</h2>
          <p class="section-text">
            I help ambitious teams ship React products that load fast, look
            sharp, and convert. Stand-out software that wins customers and moves
            metrics. High-impact frontends that boost revenue, not just
            pageviews.
          </p>
        </div>

        <div class="mission-section flex-col mt-2">
          <h2 class="section-title">Mission</h2>
          <p class="section-text">
            My mission is to help ambitious people and brands become <strong
              >unforgettable in their market</strong
            >. I turn ideas into digital realities, creating online experiences
            that not only impress, but attract the right clients and drive real
            growth.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Call to Action -->
  <div class="cta-section mt-5">
    <h2 class="cta-title">COLLABORATE WITH ME!</h2>
    <a href="projects" class="cta-button">DISCOVER MY PROJECTS</a>
  </div>

  <!-- Gallery Section -->
  <div class="gallery-section">
    <h2 class="gallery-title">GALLERY</h2>
    <div class="gallery-grid">
      <div class="gallery-item">
        <img src="/images/mobbeel-mobbmentum.jpg" alt="Project 1" />
        <div class="gallery-overlay">
          <h3>REACT DEVELOPMENT</h3>
          <p>Modern web application</p>
        </div>
      </div>
      <div class="gallery-item">
        <img src="/images/hogskulen-pa-vestlandet.jpg" alt="Project 2" />
        <div class="gallery-overlay">
          <h3>INTERNATIONAL EXPERIENCE</h3>
          <p>Global remote work</p>
        </div>
      </div>
      <div class="gallery-item">
        <img src="/images/bergen-houses.webp" alt="Project 3" />
        <div class="gallery-overlay">
          <h3>TECHNOLOGICAL INNOVATION</h3>
          <p>Creative solutions</p>
        </div>
      </div>
      <div class="gallery-item">
        <img src="/images/universidad-de-extremadura.jpg" alt="Project 4" />
        <div class="gallery-overlay">
          <h3>TECHNICAL LEADERSHIP</h3>
          <p>Mentoring and development</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #about {
    position: relative;
    z-index: 2;
    padding: 0;
    min-height: 100vh;
    background-color: var(--background-light);
  }

  /* Hero Section with Background */
  .about-hero {
    background:
      linear-gradient(135deg, rgba(30, 56, 96, 0.85), rgba(45, 74, 90, 0.75)),
      url("/images/code-in-macbook-screen-2.jpg") center/cover;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: white;
    position: relative;
  }

  .hero-content {
    max-width: 900px;
    padding: 2rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 2rem;
    color: white;
    letter-spacing: 2px;
  }

  .highlight-text {
    background: linear-gradient(135deg, var(--primary-color), #7dd3fc);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.3rem);
    letter-spacing: 3px;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 500;
    line-height: 1.6;
  }

  /* Content Section */
  .about-content {
    margin: 0 auto;
    padding: 4rem 2rem 0 2rem;
    max-width: 1100px;
    width: 100%;
  }

  /* Hero Quote Section */
  .hero-quote {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 4rem auto;
  }

  .main-quote {
    font-size: 1.8rem;
    font-weight: var(--font-semi-bold);
    color: #b8860b;
    font-style: italic;
    line-height: 1.4;
    margin: 0;
    font-family: "Montserrat", sans-serif;
  }

  .quote-author {
    display: block;
    margin-top: 1.5rem;
    font-size: 1.1rem;
    color: var(--dirty-white);
    font-weight: var(--font-semi-bold);
  }

  /* Vision and Mission */

  .vision-section {
    flex: 1;
  }
  .mission-section {
    flex: 1;
  }

  .section-title {
    text-align: left;
    font-size: 1.8rem;
    font-weight: var(--font-bold);
    color: var(--primary-color);
    margin-bottom: 1rem;
    font-family: "Montserrat", sans-serif;
    letter-spacing: 0.05em;
  }

  .section-text {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--dirty-white);
    text-align: justify;
  }

  /* Leadership Section */
  .leadership-section {
    align-items: center;
    justify-content: space-between;
  }

  .leader-photo-parent {
    width: 100%;
    justify-content: center;
    align-items: center;
  }

  .leader-photo {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 0.5rem;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
  }

  /* Call to Action */
  .cta-section {
    text-align: center;
    padding: 4rem 2rem;
    background: linear-gradient(
      135deg,
      rgba(0, 124, 240, 0.2),
      rgba(0, 223, 216, 0.2)
    );
    border-radius: 1rem;
  }

  .cta-title {
    font-size: 2.5rem;
    font-weight: var(--font-bold);
    color: var(--primary-color);
    margin-bottom: 2rem;
    font-family: "Montserrat", sans-serif;
    letter-spacing: 0.1em;
  }

  .cta-button {
    display: inline-block;
    background: var(--background-dark);
    color: var(--primary-color);
    padding: 1rem 2.5rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: var(--font-bold);
    font-size: 1rem;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    border: 2px solid var(--primary-color);
  }

  .cta-button:hover {
    background: var(--primary-color);
    color: var(--background-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 124, 240, 0.3);
  }

  /* Gallery Section */
  .gallery-section {
    max-width: 1280px;
    margin: 5rem auto 5rem auto;
    width: 100%;
    padding: 0 2rem;
  }

  .gallery-title {
    font-size: 2.2rem;
    font-weight: var(--font-bold);
    text-align: center;
    color: var(--primary-color);
    margin-bottom: 3rem;
    font-family: "Montserrat", sans-serif;
    letter-spacing: 0.1em;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    width: 100%;
    padding: 0 2rem;
  }

  .gallery-item {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    transition: transform 0.3s ease;
  }

  .gallery-item:hover {
    transform: translateY(-5px);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.1);
  }

  .gallery-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
    color: white;
    padding: 1.5rem;
    transform: translateY(100%);
    transition: transform 0.3s ease;
  }

  .gallery-item:hover .gallery-overlay {
    transform: translateY(0);
  }

  .gallery-overlay h3 {
    font-size: 1.1rem;
    font-weight: var(--font-bold);
    margin-bottom: 0.5rem;
    color: var(--primary-color);
  }

  .gallery-overlay p {
    font-size: 0.9rem;
    color: var(--dirty-white);
    margin: 0;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .main-quote {
      font-size: 1.4rem;
    }

    .leadership-section {
      flex-direction: column;
      text-align: center;
      padding: 0 1rem;
    }

    .vision-mission-section {
      flex-direction: column;
      padding: 0 1rem;
    }

    .leader-photo {
      width: 100%;
      height: 220px;
      max-width: 280px;
    }

    .cta-title {
      font-size: 2rem;
    }

    .gallery-section {
      padding: 0 1rem;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
      padding: 0 1rem;
    }

    .gallery-overlay {
      transform: translateY(0);
      background: linear-gradient(transparent, rgba(0, 0, 0, 0.9));
    }

    /* Hero Section Responsive */
    .about-hero {
      min-height: 60vh;
      padding: 1rem;
    }

    .hero-content {
      padding: 1rem;
    }

    .hero-subtitle {
      letter-spacing: 1px;
    }
  }
</style>
